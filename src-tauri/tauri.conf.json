{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-v2-schema/main/schema.json",
  "productName": "Felina",
  "version": "0.20.0",
  "identifier": "com.pershing.felina",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": "v1Compatible",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libappindicator3-1"]
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "Felina",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; connect-src 'self' https://github.com https://api.github.com http://localhost:3100"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/caioricciuti/glyphic/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU4MDI5NDU3QzRBMjlERTEKUldUaG5hTEVWNVFDNkdrZFgzQzRodG1jUEl3WHVMU2NnajJKYmpscHRVL2tQdGtkeUdvL0d0d0EK"
    },
    "shell": {
      "open": "((mailto:\\w+|tel:\\w+|https?://\\w+).+|[A-Za-z]:[\\\\/].*|/.*)"
    }
  }
}
